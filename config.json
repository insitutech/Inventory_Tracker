{
  "databases": {
    "quickbooks": {
      "connection_string": "Driver={Microsoft Access Driver (*.mdb, *.accdb)};DBQ=C:QUICKBOOKS-DATABASE-PATH;",
      "enabled": false
    },
    "access": {
      "connection_string": "Driver={Microsoft Access Driver (*.mdb, *.accdb)};DBQ=ACCESS-DATABASE-PATH;",
      "enabled": true
    }
  },
  "monitoring": {
    "interval_minutes": 30,
    "check_timeout_seconds": 300,
    "retry_attempts": 3,
    "retry_delay_seconds": 60
  },
  "thresholds": {
    "default_warning": 10,
    "default_critical": 5,
    "items": {}
  },
  "slack": {
    "webhooks": [
      {
        "name": "Production Team",
        "url": "SLACK-HOOK-URL-FOR-CHANNEL",
        "enabled": true
      }
    ],
    "notification_cooldown_minutes": 60,
    "include_item_details": true
  },
  "logging": {
    "level": "INFO",
    "file_path": "inventory_monitor.log",
    "max_file_size_mb": 10,
    "backup_count": 5
  }
}
